    <!-- ====== 6. ROOT/ADB ====== -->
    <group name="ROOT/ADB" id="5">
        <item name="开启网络ADB" click="ztShell:su -c setprop service.adb.tcp.port 5555" autoRunShell="true" dialogConfirm="true" dialogTitle="警告" dialogMessage="需要root权限，开启网络ADB(5555)？"/>
        <item name="关闭网络ADB" click="ztShell:su -c setprop service.adb.tcp.port -1" autoRunShell="true" dialogConfirm="true" dialogTitle="确认" dialogMessage="关闭网络ADB？"/>
        <item name="ADB连接设备" click="input:ADB连接@@输入IP:端口@@ztShell:adb connect {}"/>
        <item name="ADB设备列表" click="shell_output:adb devices 2>/dev/null || echo adb未安装" autoRunShell="true"/>
        <item name="ADB Shell" click="input:ADB Shell@@输入命令@@ztShell:adb shell {}"/>
        <item name="Docker检查" click="shell_output:su -c docker ps -a 2>/dev/null || echo Docker未安装" autoRunShell="true"/>
    </group>

    <!-- ====== 7. Kali Nethunter (id=10) ====== -->
    <group name="Kali Nethunter" id="10">
        <item name="安装/重装" click="internal:install_kali"/>
        <item name="Kali安装状态" click="shell_output:if [ -d ~/kali-arm64 ]; then echo Kali已安装; du -sh ~/kali-arm64 2>/dev/null | head -1; echo ---; ls ~/kali-arm64/ 2>/dev/null | head -5; else echo Kali未安装，请使用 安装/重装; fi" autoRunShell="true"/>
        <item name="启动终端" click="ztShell:nethunter" autoRunShell="true"/>
        <item name="Root终端" click="ztShell:nethunter -r" autoRunShell="true"/>
        <item name="启动桌面" click="ztShell:nethunter kex &amp;&amp; echo 按回车关闭" autoRunShell="true" dialogConfirm="true" dialogTitle="启动KeX桌面" dialogMessage="需要先设置密码。是否启动？"/>
        <item name="停止桌面" click="ztShell:nethunter kex stop" autoRunShell="true"/>
        <item name="设置密码" click="ztShell:nethunter kex passwd" autoRunShell="true"/>
        <item name="启动SSH" click="ztShell:nethunter -r service ssh start &amp;&amp; echo SSH已启动:2222 用户:root 密码:toor" autoRunShell="true"/>
        <item name="停止SSH" click="ztShell:nethunter -r service ssh stop" autoRunShell="true"/>
        <item name="安装工具集" click="ztShell:nethunter -r apt install kali-linux-default -y" autoRunShell="true" dialogConfirm="true" dialogTitle="安装工具集" dialogMessage="将安装kali-linux-default完整工具包(约10GB)，是否继续？"/>

        <!-- Kali换源 — 对齐 Termux X 的4源弹窗 -->
        <item name="Kali换源" click="commands:Kali官方源@@ztShell:echo deb http://http.kali.org/kali kali-rolling main non-free contrib > ~/kali-arm64/etc/apt/sources.list,Kali清华源@@ztShell:echo deb https://mirrors.tuna.tsinghua.edu.cn/kali kali-rolling main non-free contrib > ~/kali-arm64/etc/apt/sources.list,Kali中科大源@@ztShell:echo deb https://mirrors.ustc.edu.cn/kali kali-rolling main non-free contrib > ~/kali-arm64/etc/apt/sources.list,Kali阿里云源@@ztShell:echo deb https://mirrors.aliyun.com/kali kali-rolling main non-free contrib > ~/kali-arm64/etc/apt/sources.list" listTitle="Kali换源"/>

