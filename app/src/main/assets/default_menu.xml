    <!-- ====== 3. X11功能 ====== -->
    <group name="X11功能" id="1">
        <item name="X11设置" click="editor:/data/data/com.termux/files/home/.termux/x11.properties"/>
        <item name="显示终端" click="input:执行命令@@输入要发送的命令@@{}" autoRunShell="true"/>
        <item name="隐藏终端" click="ztShell:pkill Xvnc 2>/dev/null; pkill Xwayland 2>/dev/null; echo OK" autoRunShell="true"/>
        <item name="X11环境" click="shell_output:pkg list-installed 2>/dev/null | grep x11 || echo 无X11包" autoRunShell="true"/>
        <item name="修复环境" click="ztShell:apt --fix-broken install -y" autoRunShell="true" dialogConfirm="true" dialogTitle="修复X11" dialogMessage="是否修复X11环境？"/>
        <item name="安装X11" click="commands:安装X11工具@@ztShell:pkg install -y x11-repo xterm,打开项目页@@jumpUrl:https://github.com/termux/termux-x11" listTitle="安装X11"/>
        <item name="显示键盘" click="ztShell:echo show-extra-keys > ~/.termux/termux.properties" autoRunShell="true"/>
        <item name="隐藏键盘" click="ztShell:echo hide-extra-keys > ~/.termux/termux.properties" autoRunShell="true"/>
        <item name="VNC" click="commands:启动VNC@@ztShell:vncserver -geometry 1280x720 :1,停止VNC@@ztShell:vncserver -kill :1,安装VNC@@ztShell:pkg install -y tigervnc" listTitle="VNC操作"/>
    </group>

