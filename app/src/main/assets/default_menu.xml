        <item name="欢迎信息" click="editor:/data/data/com.termux/files/usr/etc/motd"/>
        <item name="命令定义" click="editor:/data/data/com.termux/files/home/.bash_aliases"/>
        <item name="开机命令" click="commands:编辑脚本@@editor:/data/data/com.termux/files/home/.termux/boot/start.sh,创建脚本@@ztShell:mkdir -p ~/.termux/boot" listTitle="开机命令"/>
    </group>

    <!-- ====== 10. ZT功能 ====== -->
    <group name="ZT功能" id="4">
