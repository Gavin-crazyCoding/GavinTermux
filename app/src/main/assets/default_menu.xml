    <!-- ====== 9. 配置终端 ====== -->
    <group name="配置终端" id="7">
        <item name="Shell运行" click="input:执行Shell命令@@输入命令@@{}" autoRunShell="true"/>
        <item name="底部键盘" click="editor:/data/data/com.termux/files/home/.termux/termux.properties"/>
        <item name="默认bashrc" click="ztShell:cp $PREFIX/etc/bash.bashrc.defaults $PREFIX/etc/bash.bashrc 2>/dev/null || echo 失败" autoRunShell="true" dialogConfirm="true" dialogTitle="恢复默认" dialogMessage="用默认bashrc覆盖？"/>
