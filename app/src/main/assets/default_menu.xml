<menu>

    <!-- ====== 1. 常用功能 ====== -->
    <group name="常用功能" id="0">
        <item name="切换源" click="commands:清华源@@ztShell:sed -i s@packages.termux.org@mirrors.tuna.tsinghua.edu.cn/termux@ $PREFIX/etc/apt/sources.list,北京源@@ztShell:sed -i s@packages.termux.org@mirrors.bfsu.edu.cn/termux@ $PREFIX/etc/apt/sources.list,官方源@@ztShell:pkg update -y" listTitle="选择镜像源"/>
        <item name="容器切换" click="shell_output:ls ~/.termux/container 2>/dev/null || echo 无容器目录" autoRunShell="true"/>
        <item name="备份恢复" click="commands:备份Home@@ztShell:cd ~ &amp;&amp; tar czf backup_$(date +%Y%m%d).tar.gz . 2>&amp;1,查看备份@@shell_output:ls -lh ~/backup_*.tar.gz 2>/dev/null" listTitle="备份恢复"/>
        <item name="发行版Linux" click="shell_output:ls ~/termux-install-linux* 2>/dev/null || echo 未安装" autoRunShell="true"/>
        <item name="QEMU" click="shell_output:which qemu-system-x86_64 2>/dev/null || echo QEMU未安装" autoRunShell="true"/>
        <item name="定时任务" click="commands:编辑crontab@@editor:/data/data/com.termux/files/home/.termux/crontab,查看crontab@@shell_output:crontab -l 2>/dev/null,安装cronie@@ztShell:pkg install -y cronie" listTitle="定时任务"/>
        <item name="包管理器" click="internal:pkg_manager"/>
        <item name="进程管理" click="internal:process_manager"/>
        <item name="网络工具" click="internal:network_tools"/>
        <item name="快捷命令" click="internal:quick_commands"/>
        <item name="ADB管理器" click="internal:adb_manager"/>
        <item name="AI助手" click="internal:ai_chat"/>
        <item name="Gavin设置" click="internal:settings"/>
    </group>

