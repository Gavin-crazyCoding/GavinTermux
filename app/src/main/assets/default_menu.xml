    <!-- ====== 5. 引擎 ====== -->
    <group name="引擎" id="6">
        <item name="密钥数据" click="filebrowser:/data/data/com.termux/files/home/.ssh"/>
        <item name="文件浏览" click="filebrowser:/data/data/com.termux/files/home"/>
